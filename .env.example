# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password_123
POSTGRES_DB=portfolio_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Database Connection URLs (inside docker-compose)
DATABASE_URL=postgresql+asyncpg://postgres:postgres_password_123@db:5432/portfolio_db

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Security & JWT Configuration
JWT_SECRET=super_secret_jwt_key_change_me_in_production_1928374
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email / SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=your_email@gmail.com
SMTP_TO_EMAIL=your_email@gmail.com


# Frontend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000
